<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="Questionário de Saúde"
        app:titleTextColor="@color/white"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationIconTint="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Por favor, responda com sinceridade para melhorarmos sua experiência."
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:layout_marginBottom="24dp"
                android:alpha="0.7"/>

            <!-- Question 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Utiliza medicamentos atualmente?"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                    <RadioGroup
                        android:id="@+id/rgMeds"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbMedsYes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim" />
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbMedsNo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginStart="16dp" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Question 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Possui lesões recentes?"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                    <RadioGroup
                        android:id="@+id/rgInjuries"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbInjuriesYes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim" />
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbInjuriesNo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginStart="16dp" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Question 3 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sente dores articulares frequentes?"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                    <RadioGroup
                        android:id="@+id/rgJointPain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbJointPainYes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim" />
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbJointPainNo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginStart="16dp" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Question 4 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Possui problemas cardíacos conhecidos?"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                    <RadioGroup
                        android:id="@+id/rgHeart"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbHeartYes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim" />
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbHeartNo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginStart="16dp" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Question 5 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Possui restrição médica para atividade física?"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                    <RadioGroup
                        android:id="@+id/rgRestriction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbRestrictionYes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sim" />
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbRestrictionNo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não"
                            android:layout_marginStart="16dp" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SALVAR RESPOSTAS"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>